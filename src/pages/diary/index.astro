---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DiaryCard from '../../components/DiaryCard.astro';
import { getCollection } from 'astro:content';

const diaries = (await getCollection('diary', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="日记" description="日常记录、随笔与碎碎念">

  <div class="mb-12">
    <h1 class="text-3xl md:text-4xl font-serif font-bold text-warm-900 mb-2">📝 日记</h1>
    <p class="text-warm-800">共 {diaries.length} 篇</p>
  </div>

  {
    diaries.length > 0 ? (
      <div class="max-w-3xl mx-auto">
        <div class="relative timeline pl-8">
          {diaries.map((diary) => <DiaryCard {diary} />)}
        </div>
      </div>
    ) : (
      <div class="text-center py-20">
        <p class="text-6xl mb-4">📝</p>
        <p class="text-lg text-warm-800">还没有日记</p>
        <p class="text-sm text-warm-800 mt-2">在 src/content/diary/ 下创建你的第一篇日记</p>
      </div>
    )
  }
</BaseLayout>
