---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StarRating from '../../components/StarRating.vue';
import { getCollection } from 'astro:content';

const { slug } = Astro.params;
const games = await getCollection('games', ({ data }) => !data.draft);
const game = games.find((g) => g.slug === slug);
if (!game) return Astro.redirect('/404');

const { data, body } = game;

const fmtDate = (d: Date) =>
  d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });

const { Content } = await game.render();
---

<BaseLayout title={data.title} description={data.summary || `${data.title} 游戏记录`}>
  <article class="max-w-3xl mx-auto">
    <a href="/games" class="text-sm text-warm-800 hover:text-accent transition-colors mb-8 inline-block">
      ← 返回游戏库
    </a>

    <div class="flex flex-col md:flex-row gap-8 mb-12">
      <!-- 封面 -->
      <div class="flex-shrink-0">
        {data.poster ? (
          <img src={data.poster} alt={data.title} class="w-48 h-auto rounded-xl shadow-lg object-cover" />
        ) : (
          <div class="w-48 aspect-[3/4] rounded-xl shadow-lg bg-gradient-to-br from-warm-200 to-warm-100 flex items-center justify-center">
            <span class="text-5xl">🎮</span>
          </div>
        )}
      </div>

      <!-- 元信息 -->
      <div class="flex-1">
        <h1 class="text-3xl md:text-4xl font-serif font-bold text-warm-900 mb-2">{data.title}</h1>
        {data.originalTitle && (
          <p class="text-lg text-warm-800 mb-2">{data.originalTitle}</p>
        )}

        <div class="flex items-center gap-3 mb-4">
          <StarRating rating={data.rating} size="lg" client:load />
          <span class="text-warm-800">({data.rating}/10)</span>
        </div>

        <div class="flex flex-wrap gap-4 text-sm text-warm-800 mb-4">
          {data.developer && <span>🕹 {data.developer}</span>}
          <span>📅 {fmtDate(data.playDate)}</span>
          <span>📌 {data.year} 年</span>
          <span>💿 {data.platform}</span>
        </div>

        {data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {data.tags.map((tag) => (
              <span class="text-sm px-3 py-1 bg-warm-200 text-warm-800 rounded-full">#{tag}</span>
            ))}
          </div>
        )}

        {data.summary && (
          <blockquote class="mt-6 border-l-4 border-accent pl-4 italic text-warm-800">{data.summary}</blockquote>
        )}
      </div>
    </div>

    <div class="prose max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>
